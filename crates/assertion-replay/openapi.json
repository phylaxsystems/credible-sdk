{
  "components": {
    "schemas": {
      "Assertion": {
        "properties": {
          "adopter": {
            "pattern": "^0x[a-fA-F0-9]{40}$",
            "type": "string"
          },
          "deployment_bytecode": {
            "pattern": "^0x[a-fA-F0-9]*$",
            "type": "string"
          },
          "id": {
            "pattern": "^0x[a-fA-F0-9]{64}$",
            "type": "string"
          }
        },
        "required": [
          "adopter",
          "deployment_bytecode",
          "id"
        ],
        "type": "object"
      },
      "ErrorResponse": {
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "ReplayRequest": {
        "properties": {
          "assertions": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/Assertion"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ReplayStartBlockResponse": {
        "properties": {
          "head_block": {
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          },
          "replay_window": {
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          },
          "start_block": {
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "start_block",
          "head_block",
          "replay_window"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Phylax Systems"
    },
    "description": "",
    "license": {
      "identifier": "BSL 1.1",
      "name": "BSL 1.1"
    },
    "title": "assertion-replay",
    "version": "1.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "health_handler",
        "responses": {
          "200": {
            "description": "Service is healthy"
          }
        },
        "tags": [
          "assertion-replay"
        ]
      }
    },
    "/replay": {
      "post": {
        "operationId": "replay_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReplayRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Replay completed"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid payload"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Replay failed"
          }
        },
        "tags": [
          "assertion-replay"
        ]
      }
    },
    "/replay/start-block": {
      "get": {
        "operationId": "replay_start_block_handler",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReplayStartBlockResponse"
                }
              }
            },
            "description": "Replay start-block preview"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Failed to compute replay start-block"
          }
        },
        "tags": [
          "assertion-replay"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "Replay service API",
      "name": "assertion-replay"
    }
  ]
}
